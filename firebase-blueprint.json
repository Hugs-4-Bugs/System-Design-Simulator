{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about the user",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user" },
        "displayName": { "type": "string", "description": "The display name of the user" },
        "email": { "type": "string", "format": "email", "description": "The email of the user" },
        "photoURL": { "type": "string", "description": "The URL of the user's photo" },
        "lastLogin": { "type": "string", "format": "date-time", "description": "The last login time" }
      },
      "required": ["uid", "email"]
    },
    "Design": {
      "title": "Architecture Design",
      "description": "A saved architecture design",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the design" },
        "name": { "type": "string", "description": "The name of the design" },
        "ownerUid": { "type": "string", "description": "The UID of the owner" },
        "nodes": { "type": "string", "description": "Serialized JSON string of nodes" },
        "edges": { "type": "string", "description": "Serialized JSON string of edges" },
        "createdAt": { "type": "string", "format": "date-time", "description": "The creation time" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "The last update time" }
      },
      "required": ["id", "name", "ownerUid", "nodes", "edges"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/designs/{designId}": {
      "schema": "Design",
      "description": "Architecture design documents"
    }
  }
}
